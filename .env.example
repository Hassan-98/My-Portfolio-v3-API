# Main Server Info
HOST=http://localhost
PORT=9999

# Node Env
NODE_ENV=development

# MongoDB Configuration
MONGO_USER=
MONGO_PASSWORD=
MONGO_PATH=
MONGO_DATABASE=
MONGO_DEV_DATABASE=

# Whitelisted Domains
WHITELISTED_DOMAINS=http://localhost:3000|http://localhost:3001

# CLIENT URL for sending email messages
CLIENT_URL=http://localhost:3000

# API Secrets
JWT_SECRET=
COOKIE_SECRET=
CRYPTO_SECRET=


# Mailgun Credientials
MAILGUN_USERNAME=
MAILGUN_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECERT=

# Google Cloud Storage Service Account Data (required when STORAGE_PROVIDER=firebase)
ServiceAccount_project_id=
ServiceAccount_private_key=
ServiceAccount_client_email=

# File storage: "firebase" (GCS) or "telegram" (Bot API + proxy URLs at /media/:id)
STORAGE_PROVIDER=firebase

# Telegram Bot API (required when STORAGE_PROVIDER=telegram) — https://core.telegram.org/bots/api
# Create a bot with @BotFather, then add the token here (same as TELEGRAM_bot_token if you use that alias).
TELEGRAM_BOT_TOKEN=
# Chat where the bot sends files (Bot API chat_id). Not "me". Examples: private channel id -100… (bot must be admin), or your numeric user id in DMs after /start.
TELEGRAM_STORAGE_PEER=
# Optional: self-hosted Bot API server base URL (default https://api.telegram.org)
TELEGRAM_BOT_API_BASE=https://api.telegram.org
# Public base URL of this API (no trailing slash required), e.g. https://api.example.com — used for /media/:id links
API_PUBLIC_URL=

# GOOGLE LOGIN EMAIL
GOOGLE_LOGIN_EMAIL=
